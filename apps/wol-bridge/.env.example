# Linux Mint WoL bridge environment.
# PROTOCOL.md §14 (Config Validation) — these are required.

# Shared bridge token (must match the relay's GHOSTYC_BRIDGE_TOKEN).
GHOSTYC_BRIDGE_TOKEN=

# Where the relay lives. http://… or https://… are accepted; the bridge
# rewrites them to ws:// / wss:// internally for the /ws/bridge endpoint.
RELAY_URL=http://localhost:8080

# Target PC for Wake-on-LAN.
# MAC — AA:BB:CC:DD:EE:FF, AA-BB-CC-DD-EE-FF, or AABBCCDDEEFF (case-insensitive).
PC_MAC_ADDRESS=
# Primary subnet broadcast (e.g. 192.168.1.255). When WOL_MULTI_SEND=true,
# the bridge also sends to 255.255.255.255 and tries port 7 in addition to WOL_PORT.
PC_BROADCAST_ADDRESS=192.168.1.255

# UDP destination port for WoL (default 9). With multi-send, port 7 is also used.
WOL_PORT=9
# true (default): send to PC_BROADCAST_ADDRESS and 255.255.255.255, each on WOL_PORT and 7.
# false: single send to PC_BROADCAST_ADDRESS:WOL_PORT only.
WOL_MULTI_SEND=true

# Optional: bind the UDP socket to this local IPv4 so the packet exits the correct NIC.
# Takes precedence over WOL_INTERFACE when both are set.
WOL_LOCAL_ADDRESS=
# Optional: bind using the first non-internal IPv4 on this interface (e.g. enp3s0, eth0).
WOL_INTERFACE=

# Optional: where bridge JSONL logs are written. Defaults to ./logs.
GHOSTYC_BRIDGE_LOG_DIR=./logs
