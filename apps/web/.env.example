# Production (Railway): point the static web app at the relay service.
# Baked in at `vite build` time.
VITE_API_BASE_URL=https://ghostyc-production.up.railway.app
VITE_WS_BASE_URL=wss://ghostyc-production.up.railway.app

# Optional legacy fallback (same as API base if you still use one var).
# VITE_RELAY_URL=https://ghostyc-production.up.railway.app

# Local dev: leave API/WS empty to use Vite proxy (see vite.config.ts) to localhost:8080.
